{
  "name": "@tracksheet/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "node dist/index.js",
    "seed:admin": "bun run src/scripts/seedAdmin.ts",
    "build": "npx esbuild@0.25.0 src/index.ts --bundle --outdir=dist --platform=node --target=node22 --format=esm --external:@opentelemetry/api",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracksheet/shared": "file:../../packages/shared",
    "better-auth": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.19.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "bun-types": "^1.3.11",
    "typescript": "*"
  }
}
